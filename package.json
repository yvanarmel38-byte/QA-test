{
  "name": "qa-assessment-automation",
  "version": "1.0.0",
  "description": "Playwright automation suite for the QA assessment user profile creation form",
  "scripts": {
    "test": "playwright test",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:ci": "playwright test --reporter=html,allure-playwright",
    "report:html": "playwright show-report",
    "report:allure": "allure generate allure-results --clean -o allure-report && allure open allure-report",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.43.0",
    "@types/node": "^25.5.2",
    "allure-playwright": "^3.0.0",
    "dotenv": "^16.4.5",
    "typescript": "^5.4.5"
  }
}
